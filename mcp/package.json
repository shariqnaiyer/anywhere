{
  "name": "things-mcp",
  "version": "0.1.0",
  "description": "MCP server for Things 3 via things-api",
  "type": "module",
  "bin": {
    "things-mcp": "./bin/things-mcp.js"
  },
  "main": "./dist/index.js",
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . --watch",
    "start": "node dist/index.js",
    "dev": "tsc -p . && node dist/index.js",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p . --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
